  "item": [
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/health"
          }
        },
        {
          "name": "Health DB",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/health/db"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@example.com\",\n  \"password\": \"travelhub\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Register (traveler)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo.usuario@example.com\",\n  \"username\": \"Nuevo Usuario\",\n  \"phone\": \"+573001112233\",\n  \"country_code\": \"CO\",\n  \"password\": \"travelhub\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Admin register partner (hotel/agency)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Partner-Admin-Key",
                "value": "{{partnerAdminSecret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Demo\",\n  \"last_name\": \"Manager\",\n  \"phone\": \"+521551112233\",\n  \"email\": \"partner.demo@example.com\",\n  \"country_code\": \"MX\",\n  \"password\": \"travelhub\",\n  \"organization_type\": \"HOTEL\",\n  \"organization_id\": \"e0000000-0000-0000-0000-000000000001\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/admin/partner-users"
          }
        },
        {
          "name": "Get me (cookie)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
