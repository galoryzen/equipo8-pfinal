{
  "info": {
    "_postman_id": "b2c3d4e5-travelhub-direct",
    "name": "TravelHub — Servicios directos (sin gateway)",
    "description": "Mismas rutas que la colección del gateway pero contra cada microservicio en su puerto local (mapeo docker-compose.yml).\n\n- auth: 8001\n- catalog: 8002\n- booking: 8003\n- payment: 8004\n- notification: 8005\n\n**Booking / Payment:** usa `Authorization: Bearer {{accessToken}}` (copiar JWT tras Login; para flujo mock de pago usar **maria@example.com** / **travelhub** y variables `bookingIdPayable`, `paymentIntentId`, `mockPaymentToken`, `webhookSecret`).\n\nÚtil si nginx no está levantado o para depurar un solo servicio.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "authUrl", "value": "http://localhost:8001" },
    { "key": "catalogUrl", "value": "http://localhost:8002" },
    { "key": "bookingUrl", "value": "http://localhost:8003" },
    { "key": "paymentUrl", "value": "http://localhost:8004" },
    { "key": "notificationUrl", "value": "http://localhost:8005" },
    { "key": "propertyId", "value": "30000000-0000-0000-0000-000000000001" },
    { "key": "bookingId", "value": "90000000-0000-0000-0000-000000000001" },
    { "key": "accessToken", "value": "" },
    { "key": "partnerAdminSecret", "value": "dev-partner-admin-secret" },
    { "key": "bookingIdPayable", "value": "90000000-0000-0000-0000-000000000002" },
    { "key": "paymentIntentId", "value": "" },
    { "key": "mockPaymentToken", "value": "" },
    { "key": "webhookSecret", "value": "" },
    { "key": "webhookIdempotencyKey", "value": "" }
  ],
  "item": [
    {
      "name": "Auth :8001",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{authUrl}}/api/v1/auth/health" }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@example.com\",\n  \"password\": \"travelhub\"\n}"
            },
            "url": "{{authUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Get me",
          "request": { "method": "GET", "url": "{{authUrl}}/api/v1/auth/me" }
        },
        {
          "name": "Admin register partner (hotel/agency)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Partner-Admin-Key", "value": "{{partnerAdminSecret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Demo\",\n  \"last_name\": \"Manager\",\n  \"phone\": \"+521551112233\",\n  \"email\": \"partner.demo@example.com\",\n  \"country_code\": \"MX\",\n  \"password\": \"travelhub\",\n  \"organization_type\": \"HOTEL\",\n  \"organization_id\": \"e0000000-0000-0000-0000-000000000001\"\n}"
            },
            "url": "{{authUrl}}/api/v1/auth/admin/partner-users"
          }
        }
      ]
    },
    {
      "name": "Catalog :8002",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{catalogUrl}}/api/v1/catalog/health" }
        },
        {
          "name": "Search properties",
          "request": {
            "method": "GET",
            "url": "{{catalogUrl}}/api/v1/catalog/properties?checkin=2026-04-15&checkout=2026-04-20&guests=2"
          }
        },
        {
          "name": "Cities search",
          "request": { "method": "GET", "url": "{{catalogUrl}}/api/v1/catalog/cities?q=bo" }
        },
        {
          "name": "Property detail",
          "request": {
            "method": "GET",
            "url": "{{catalogUrl}}/api/v1/catalog/properties/{{propertyId}}"
          }
        }
      ]
    },
    {
      "name": "Booking :8003",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{bookingUrl}}/api/v1/booking/health" }
        },
        {
          "name": "List my bookings",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{bookingUrl}}/api/v1/booking/bookings",
            "description": "Alternativa: `Cookie: access_token=<jwt>`"
          },
          "response": [
            {
              "name": "200 — con reservas (ejemplo)",
              "originalRequest": {
                "method": "GET",
                "url": "{{bookingUrl}}/api/v1/booking/bookings"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "[\n  {\n    \"id\": \"90000000-0000-0000-0000-000000000001\",\n    \"status\": \"CONFIRMED\",\n    \"checkin\": \"2026-05-20\",\n    \"checkout\": \"2026-05-23\",\n    \"total_amount\": \"360.00\",\n    \"currency_code\": \"USD\",\n    \"created_at\": \"2026-04-01T12:00:00\",\n    \"items\": [\n      {\n        \"property_id\": \"30000000-0000-0000-0000-000000000001\",\n        \"room_type_id\": \"60000000-0000-0000-0000-000000000001\",\n        \"quantity\": 1\n      }\n    ]\n  }\n]"
            },
            {
              "name": "200 — sin reservas",
              "originalRequest": {
                "method": "GET",
                "url": "{{bookingUrl}}/api/v1/booking/bookings"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "[]"
            }
          ]
        },
        {
          "name": "Get booking detail",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{bookingUrl}}/api/v1/booking/bookings/{{bookingId}}"
          },
          "response": [
            {
              "name": "200 — reserva propia (ejemplo)",
              "originalRequest": {
                "method": "GET",
                "url": "{{bookingUrl}}/api/v1/booking/bookings/{{bookingId}}"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "{\n  \"id\": \"90000000-0000-0000-0000-000000000001\",\n  \"status\": \"CONFIRMED\",\n  \"checkin\": \"2026-05-20\",\n  \"checkout\": \"2026-05-23\",\n  \"hold_expires_at\": null,\n  \"total_amount\": \"360.00\",\n  \"currency_code\": \"USD\",\n  \"policy_type_applied\": \"FULL\",\n  \"policy_hours_limit_applied\": 48,\n  \"policy_refund_percent_applied\": 100,\n  \"created_at\": \"2026-04-01T12:00:00\",\n  \"updated_at\": \"2026-04-01T12:00:00\",\n  \"items\": [\n    {\n      \"id\": \"91000000-0000-0000-0000-000000000001\",\n      \"property_id\": \"30000000-0000-0000-0000-000000000001\",\n      \"room_type_id\": \"60000000-0000-0000-0000-000000000001\",\n      \"rate_plan_id\": \"70000000-0000-0000-0000-000000000001\",\n      \"quantity\": 1,\n      \"unit_price\": \"120.00\",\n      \"subtotal\": \"360.00\"\n    }\n  ]\n}"
            },
            {
              "name": "404 — no existe o no pertenece",
              "originalRequest": {
                "method": "GET",
                "url": "{{bookingUrl}}/api/v1/booking/bookings/00000000-0000-0000-0000-000000000099"
              },
              "status": "Not Found",
              "code": 404,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "{\n  \"code\": \"BOOKING_NOT_FOUND\",\n  \"message\": \"Booking not found\",\n  \"trace_id\": null\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Payment :8004",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{paymentUrl}}/api/v1/payment/health" }
        },
        {
          "name": "Health DB",
          "request": { "method": "GET", "url": "{{paymentUrl}}/api/v1/payment/health/db" }
        },
        {
          "name": "Create payment intent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": \"{{bookingIdPayable}}\"\n}"
            },
            "url": "{{paymentUrl}}/api/v1/payment/payment-intents"
          }
        },
        {
          "name": "Confirm payment intent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_token\": \"{{mockPaymentToken}}\"\n}"
            },
            "url": "{{paymentUrl}}/api/v1/payment/payment-intents/{{paymentIntentId}}/confirm"
          }
        },
        {
          "name": "Mock webhook (succeeded)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_intent_id\": \"{{paymentIntentId}}\",\n  \"status\": \"succeeded\",\n  \"idempotency_key\": \"{{webhookIdempotencyKey}}\",\n  \"webhook_signing_secret\": \"{{webhookSecret}}\"\n}"
            },
            "url": "{{paymentUrl}}/api/v1/payment/webhooks/mock"
          }
        }
      ]
    },
    {
      "name": "Notifications :8005",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{notificationUrl}}/api/v1/notifications/health" }
        }
      ]
    }
  ]
}
